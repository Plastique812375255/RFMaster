{
  "name": "rfmaster",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "patchedDependencies": {
      "nw@0.94.1": "patches/nw@0.94.1.patch"
    }
  },
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.html",
  "node-remote": "http://localhost:*",
  "chromium-args": "--disable-dev-shm-usage",
  "permissions": [
    "serial"
  ],
  "window": {
    "title": "RFMaster",
    "width": 1280,
    "height": 800,
    "min_width": 400,
    "min_height": 300
  },
  "scripts": {
    "postinstall": "node scripts/ensure-nw-sdk.mjs",
    "start": "vite build && node scripts/run-nw.mjs",
    "dev": "vite",
    "vite-only": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/chrome": "^0.0.287",
    "@types/semver": "^7.5.8",
    "@types/w3c-web-serial": "^1.0.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "nw": "^0.94.0",
    "prettier": "^3.4.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  }
}
