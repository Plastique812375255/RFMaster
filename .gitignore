# Vite 构建产物（pnpm build / pnpm start 会生成）
dist/
dist-ssr/

# Vite / 工具缓存
.vite/
.cache/

# 测试与覆盖率
coverage/
*.lcov

# TypeScript 增量缓存
*.tsbuildinfo

# 日志
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# 本地/密钥（若以后有）
.env
.env.*.local

# 操作系统
.DS_Store
Thumbs.db

# 编辑器（按需保留；若希望共享团队设置可删掉下面几行）
.idea/
*.swp
*.swo
